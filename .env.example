# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Britium Express Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── API Base URL (optional) ───────────────────────────────────────────────────
# Leave empty for same-origin Vercel serverless functions.
# Set to https://api.yourdomain.com for a separate backend.
VITE_API_BASE_URL=

# ── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to use mock API responses (for local dev without Supabase)
VITE_ENABLE_MOCK=false

# ── Server-side only (Vercel serverless functions) ────────────────────────────
# These MUST NOT have the VITE_ prefix — they are never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
