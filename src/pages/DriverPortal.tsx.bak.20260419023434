import { useState, useEffect } from 'react';
import { useLocation } from 'react-router-dom';
import { motion, AnimatePresence } from 'framer-motion';
import {
  Package,
  MapPin,
  Navigation,
  CheckCircle,
  Camera,
  FileSignature,
  Hash,
  Clock,
  DollarSign,
  AlertCircle,
  Phone,
  ChevronRight,
  TrendingUp,
  Award,
  Target,
} from 'lucide-react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Progress } from '@/components/ui/progress';
import { Separator } from '@/components/ui/separator';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Avatar, AvatarFallback } from '@/components/ui/avatar';
import { IMAGES } from '@/assets/images';
import {
  formatStatus,
  getStatusColor,
  formatDate,
  formatCurrency,
  formatDistance,
  formatDuration,
  type Delivery,
  type Shipment,
  type Manifest,
  type Employee,
} from '@/lib/index';
import { mockDeliveries, mockShipments, mockManifests, mockEmployees } from '@/data/index';
import { StatusBadge, CompactMetric, ProgressMetric } from '@/components/Stats';
import { MapView } from '@/components/MapView';
import { springPresets, fadeInUp, staggerContainer, staggerItem } from '@/lib/motion';

const currentDriverId = 'emp-003';

export default function DriverPortal() {
  const location = useLocation();
  const getInitialDriverTab = () => {
    if (location.pathname.includes('/jobs')) return 'jobs';
    if (location.pathname.includes('/route')) return 'route';
    if (location.pathname.includes('/proof')) return 'proof';
    return 'jobs';
    if (location.pathname.includes('/earnings')) return 'earnings';
  };
  const [activeTab, setActiveTab] = useState(getInitialDriverTab());
  const [selectedDelivery, setSelectedDelivery] = useState<string | null>(null);
  const [currentDriver, setCurrentDriver] = useState<Employee | null>(null);
  const [activeManifest, setActiveManifest] = useState<Manifest | null>(null);
  const [myDeliveries, setMyDeliveries] = useState<Delivery[]>([]);
  const [myShipments, setMyShipments] = useState<Shipment[]>([]);

  useEffect(() => {
    const driver = mockEmployees.find(e => e.id === currentDriverId);
    setCurrentDriver(driver || null);

    const manifest = mockManifests.find(m => m.driverId === currentDriverId && m.status === 'active');
    setActiveManifest(manifest || null);

    const deliveries = mockDeliveries.filter(d => d.driverId === currentDriverId);
    setMyDeliveries(deliveries);

    const shipmentIds = deliveries.map(d => d.shipmentId);
    const shipments = mockShipments.filter(s => shipmentIds.includes(s.id));
    setMyShipments(shipments);
  }, []);

  const activeDeliveries = myDeliveries.filter(d =>
    ['assigned', 'picked-up', 'in-transit', 'out-for-delivery'].includes(d.status)
  );

  const completedToday = myDeliveries.filter(d => {
    if (d.status !== 'delivered' || !d.deliveredAt) return false;
    const deliveredDate = new Date(d.deliveredAt);
    const today = new Date();
    return deliveredDate.toDateString() === today.toDateString();
  });

  const todayEarnings = completedToday.reduce((sum, d) => {
    const shipment = myShipments.find(s => s.id === d.shipmentId);
    if (!shipment) return sum;
    const baseRate = 5000;
    return sum + baseRate;
  }, 0);

  const codCollectedToday = completedToday.reduce((sum, d) => sum + (d.codCollected || 0), 0);

  const getShipmentForDelivery = (deliveryId: string) => {
    const delivery = myDeliveries.find(d => d.id === deliveryId);
    if (!delivery) return null;
    return myShipments.find(s => s.id === delivery.shipmentId) || null;
  };

  const handleStartDelivery = (deliveryId: string) => {
    setSelectedDelivery(deliveryId);
    setActiveTab('route');
  };

  const handleCompleteDelivery = (deliveryId: string) => {
    setSelectedDelivery(deliveryId);
    setActiveTab('proof');
  };

  return (
    <div className="min-h-screen bg-background">
      {/* Hero Header */}
      <div className="relative h-64 overflow-hidden">
        <img
          src={IMAGES.SCREENSHOT_3252_4}
          alt="Driver Portal"
          className="absolute inset-0 w-full h-full object-cover opacity-30"
        />
        <div className="absolute inset-0 bg-gradient-to-b from-background/50 via-transparent to-background/70" />
        <div className="relative h-full flex flex-col justify-end p-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={springPresets.gentle}
          >
            <div className="flex items-center gap-4 mb-4">
              <Avatar className="h-16 w-16 border-2 border-primary">
                <AvatarFallback className="bg-primary text-primary-foreground text-xl font-bold">
                  {currentDriver?.name.split(' ').map(n => n[0]).join('') || 'DR'}
                </AvatarFallback>
              </Avatar>
              <div>
                <h1 className="text-3xl font-bold text-foreground">
                  {currentDriver?.name || 'Driver Portal'}
                </h1>
                <p className="text-muted-foreground">
                  {currentDriver?.vehicleAssignment?.vehicleType.toUpperCase()} •{' '}
                  {currentDriver?.vehicleAssignment?.licensePlate}
                </p>
              </div>
            </div>
          </motion.div>
        </div>
      </div>

      {/* Quick Stats */}
      <div className="px-8 -mt-8 mb-8">
        <motion.div
          variants={staggerContainer}
          initial="hidden"
          animate="visible"
          className="grid grid-cols-1 md:grid-cols-4 gap-4"
        >
          <motion.div variants={staggerItem}>
            <Card className="bg-card/80 backdrop-blur border-border/50">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm text-muted-foreground">Active Jobs</p>
                    <p className="text-3xl font-bold text-foreground">{activeDeliveries.length}</p>
                  </div>
                  <div className="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center">
                    <Package className="h-6 w-6 text-primary" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>

          <motion.div variants={staggerItem}>
            <Card className="bg-card/80 backdrop-blur border-border/50">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm text-muted-foreground">Completed Today</p>
                    <p className="text-3xl font-bold text-chart-3">{completedToday.length}</p>
                  </div>
                  <div className="h-12 w-12 rounded-full bg-chart-3/10 flex items-center justify-center">
                    <CheckCircle className="h-6 w-6 text-chart-3" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>

          <motion.div variants={staggerItem}>
            <Card className="bg-card/80 backdrop-blur border-border/50">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm text-muted-foreground">Today's Earnings</p>
                    <p className="text-3xl font-bold text-chart-4">{formatCurrency(todayEarnings)}</p>
                  </div>
                  <div className="h-12 w-12 rounded-full bg-chart-4/10 flex items-center justify-center">
                    <DollarSign className="h-6 w-6 text-chart-4" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>

          <motion.div variants={staggerItem}>
            <Card className="bg-card/80 backdrop-blur border-border/50">
              <CardContent className="p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm text-muted-foreground">Success Rate</p>
                    <p className="text-3xl font-bold text-primary">
                      {((currentDriver?.performance?.successRate) ?? 0).toFixed(1)}%
                    </p>
                  </div>
                  <div className="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center">
                    <Award className="h-6 w-6 text-primary" />
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>
        </motion.div>
      </div>

      {/* Main Content */}
      <div className="px-8 pb-8">
        <Tabs value={activeTab} onValueChange={setActiveTab} className="space-y-6">
          <TabsList className="grid w-full grid-cols-4 lg:w-auto lg:inline-grid">
            <TabsTrigger value="jobs" className="gap-2">
              <Package className="h-4 w-4" />
              Current Jobs
            </TabsTrigger>
            <TabsTrigger value="route" className="gap-2">
              <Navigation className="h-4 w-4" />
              Active Route
            </TabsTrigger>
            <TabsTrigger value="proof" className="gap-2">
              <CheckCircle className="h-4 w-4" />
              Proof of Delivery
            </TabsTrigger>
            <TabsTrigger value="earnings" className="gap-2">
              <DollarSign className="h-4 w-4" />
              Earnings
            </TabsTrigger>
          </TabsList>

          {/* Current Jobs Tab */}
          <TabsContent value="jobs" className="space-y-6">
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={springPresets.gentle}
            >
              <Card>
                <CardHeader>
                  <CardTitle>Active Deliveries</CardTitle>
                  <CardDescription>
                    {activeDeliveries.length} deliveries in progress
                  </CardDescription>
                </CardHeader>
                <CardContent>
                  <ScrollArea className="h-[600px] pr-4">
                    <div className="space-y-4">
                      {activeDeliveries.map((delivery, index) => {
                        const shipment = getShipmentForDelivery(delivery.id);
                        if (!shipment) return null;

                        return (
                          <motion.div
                            key={delivery.id}
                            initial={{ opacity: 0, x: -20 }}
                            animate={{ opacity: 1, x: 0 }}
                            transition={{ delay: index * 0.1, ...springPresets.snappy }}
                          >
                            <Card className="border-l-4 border-l-primary hover:shadow-lg transition-shadow">
                              <CardContent className="p-6">
                                <div className="flex items-start justify-between mb-4">
                                  <div className="flex-1">
                                    <div className="flex items-center gap-2 mb-2">
                                      <Badge variant="outline" className="font-mono">
                                        {shipment.awb}
                                      </Badge>
                                      <StatusBadge status={delivery.status} size="sm" />
                                    </div>
                                    <h3 className="font-semibold text-lg mb-1">
                                      {shipment.recipient.name}
                                    </h3>
                                    <div className="flex items-start gap-2 text-sm text-muted-foreground">
                                      <MapPin className="h-4 w-4 mt-0.5 flex-shrink-0" />
                                      <span>
                                        {shipment.recipient.address.street},{' '}
                                        {shipment.recipient.address.city}
                                      </span>
                                    </div>
                                  </div>
                                  <Button
                                    size="sm"
                                    onClick={() => handleStartDelivery(delivery.id)}
                                    className="gap-2"
                                  >
                                    <Navigation className="h-4 w-4" />
                                    Navigate
                                  </Button>
                                </div>

                                <Separator className="my-4" />

                                <div className="grid grid-cols-2 gap-4">
                                  <div className="flex items-center gap-2">
                                    <Phone className="h-4 w-4 text-muted-foreground" />
                                    <span className="text-sm">{shipment.recipient.phone}</span>
                                  </div>
                                  <div className="flex items-center gap-2">
                                    <Package className="h-4 w-4 text-muted-foreground" />
                                    <span className="text-sm">
                                      {shipment.packageDetails.weight} kg
                                    </span>
                                  </div>
                                  {shipment.codAmount && (
                                    <div className="flex items-center gap-2">
                                      <DollarSign className="h-4 w-4 text-muted-foreground" />
                                      <span className="text-sm font-semibold text-chart-4">
                                        COD: {formatCurrency(shipment.codAmount)}
                                      </span>
                                    </div>
                                  )}
                                  {shipment.specialInstructions && (
                                    <div className="flex items-center gap-2 col-span-2">
                                      <AlertCircle className="h-4 w-4 text-chart-4" />
                                      <span className="text-sm text-chart-4">
                                        {shipment.specialInstructions}
                                      </span>
                                    </div>
                                  )}
                                </div>

                                {delivery.status === 'out-for-delivery' && (
                                  <Button
                                    className="w-full mt-4 gap-2"
                                    onClick={() => handleCompleteDelivery(delivery.id)}
                                  >
                                    <CheckCircle className="h-4 w-4" />
                                    Complete Delivery
                                  </Button>
                                )}
                              </CardContent>
                            </Card>
                          </motion.div>
                        );
                      })}

                      {activeDeliveries.length === 0 && (
                        <div className="text-center py-12">
                          <Package className="h-12 w-12 text-muted-foreground mx-auto mb-4" />
                          <p className="text-muted-foreground">No active deliveries</p>
                        </div>
                      )}
                    </div>
                  </ScrollArea>
                </CardContent>
              </Card>
            </motion.div>
          </TabsContent>

          {/* Active Route Tab */}
          <TabsContent value="route" className="space-y-6">
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div className="lg:col-span-2">
                <Card>
                  <CardHeader>
                    <CardTitle>Route Map</CardTitle>
                    <CardDescription>
                      Turn-by-turn navigation for your deliveries
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <div className="relative h-[500px] rounded-lg overflow-hidden bg-muted">
                      <img
                        src={IMAGES.ROUTE_MAP_1}
                        alt="Route Map"
                        className="absolute inset-0 w-full h-full object-cover"
                      />
                      <div className="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent" />
                      <div className="absolute bottom-4 left-4 right-4">
                        <Card className="bg-card/90 backdrop-blur">
                          <CardContent className="p-4">
                            <div className="flex items-center justify-between">
                              <div>
                                <p className="text-sm text-muted-foreground">Next Stop</p>
                                <p className="font-semibold">
                                  {activeDeliveries[0] &&
                                    getShipmentForDelivery(activeDeliveries[0].id)?.recipient.name}
                                </p>
                              </div>
                              <div className="text-right">
                                <p className="text-sm text-muted-foreground">ETA</p>
                                <p className="font-semibold">15 min</p>
                              </div>
                            </div>
                          </CardContent>
                        </Card>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </div>

              <div>
                <Card>
                  <CardHeader>
                    <CardTitle>Delivery Manifest</CardTitle>
                    <CardDescription>
                      {activeManifest ? `${activeManifest.deliveries.length} stops` : 'No active manifest'}
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    {activeManifest ? (
                      <ScrollArea className="h-[500px] pr-4">
                        <div className="space-y-3">
                          {activeManifest.route.waypoints.map((waypoint, index) => {
                            const delivery = myDeliveries.find(d => d.id === waypoint.deliveryId);
                            const shipment = delivery ? getShipmentForDelivery(delivery.id) : null;
                            if (!shipment) return null;

                            const isCompleted = delivery?.status === 'delivered';
                            const isCurrent = index === 0 && !isCompleted;

                            return (
                              <div
                                key={waypoint.deliveryId}
                                className={`flex items-start gap-3 p-3 rounded-lg border ${
                                  isCurrent
                                    ? 'border-primary bg-primary/5'
                                    : isCompleted
                                    ? 'border-chart-3 bg-chart-3/5'
                                    : 'border-border'
                                }`}
                              >
                                <div
                                  className={`flex-shrink-0 h-8 w-8 rounded-full flex items-center justify-center font-semibold ${
                                    isCompleted
                                      ? 'bg-chart-3 text-white'
                                      : isCurrent
                                      ? 'bg-primary text-primary-foreground'
                                      : 'bg-muted text-muted-foreground'
                                  }`}
                                >
                                  {isCompleted ? (
                                    <CheckCircle className="h-4 w-4" />
                                  ) : (
                                    waypoint.sequence
                                  )}
                                </div>
                                <div className="flex-1 min-w-0">
                                  <p className="font-medium text-sm truncate">
                                    {shipment.recipient.name}
                                  </p>
                                  <p className="text-xs text-muted-foreground truncate">
                                    {waypoint.address.street}
                                  </p>
                                  {shipment.codAmount && (
                                    <p className="text-xs font-semibold text-chart-4 mt-1">
                                      COD: {formatCurrency(shipment.codAmount)}
                                    </p>
                                  )}
                                </div>
                                {isCurrent && (
                                  <ChevronRight className="h-5 w-5 text-primary flex-shrink-0" />
                                )}
                              </div>
                            );
                          })}
                        </div>
                      </ScrollArea>
                    ) : (
                      <div className="text-center py-12">
                        <Navigation className="h-12 w-12 text-muted-foreground mx-auto mb-4" />
                        <p className="text-muted-foreground">No active route</p>
                      </div>
                    )}
                  </CardContent>
                </Card>
              </div>
            </div>
          </TabsContent>

          {/* Proof of Delivery Tab */}
          <TabsContent value="proof" className="space-y-6">
            <Card>
              <CardHeader>
                <CardTitle>Proof of Delivery Checklist</CardTitle>
                <CardDescription>
                  Complete all steps to finalize delivery
                </CardDescription>
              </CardHeader>
              <CardContent>
                <div className="max-w-2xl mx-auto space-y-6">
                  {selectedDelivery && (
                    <div className="mb-6">
                      <div className="flex items-center gap-2 mb-2">
                        <Badge variant="outline" className="font-mono">
                          {getShipmentForDelivery(selectedDelivery)?.awb}
                        </Badge>
                      </div>
                      <h3 className="text-lg font-semibold">
                        {getShipmentForDelivery(selectedDelivery)?.recipient.name}
                      </h3>
                      <p className="text-sm text-muted-foreground">
                        {getShipmentForDelivery(selectedDelivery)?.recipient.address.street}
                      </p>
                    </div>
                  )}

                  <Separator />

                  <div className="space-y-4">
                    <div className="flex items-start gap-4 p-4 rounded-lg border border-border hover:border-primary transition-colors">
                      <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <Camera className="h-5 w-5 text-primary" />
                      </div>
                      <div className="flex-1">
                        <h4 className="font-semibold mb-1">Take Photo</h4>
                        <p className="text-sm text-muted-foreground mb-3">
                          Capture photo of delivered package
                        </p>
                        <Button variant="outline" size="sm" className="gap-2">
                          <Camera className="h-4 w-4" />
                          Open Camera
                        </Button>
                      </div>
                    </div>

                    <div className="flex items-start gap-4 p-4 rounded-lg border border-border hover:border-primary transition-colors">
                      <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <FileSignature className="h-5 w-5 text-primary" />
                      </div>
                      <div className="flex-1">
                        <h4 className="font-semibold mb-1">Get Signature</h4>
                        <p className="text-sm text-muted-foreground mb-3">
                          Collect recipient's signature
                        </p>
                        <Button variant="outline" size="sm" className="gap-2">
                          <FileSignature className="h-4 w-4" />
                          Signature Pad
                        </Button>
                      </div>
                    </div>

                    <div className="flex items-start gap-4 p-4 rounded-lg border border-border hover:border-primary transition-colors">
                      <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <Hash className="h-5 w-5 text-primary" />
                      </div>
                      <div className="flex-1">
                        <h4 className="font-semibold mb-1">Verify OTP</h4>
                        <p className="text-sm text-muted-foreground mb-3">
                          Enter OTP from recipient
                        </p>
                        <Button variant="outline" size="sm" className="gap-2">
                          <Hash className="h-4 w-4" />
                          Enter OTP
                        </Button>
                      </div>
                    </div>

                    <div className="flex items-start gap-4 p-4 rounded-lg border border-border hover:border-primary transition-colors">
                      <div className="h-10 w-10 rounded-full bg-chart-4/10 flex items-center justify-center flex-shrink-0">
                        <DollarSign className="h-5 w-5 text-chart-4" />
                      </div>
                      <div className="flex-1">
                        <h4 className="font-semibold mb-1">Collect COD</h4>
                        <p className="text-sm text-muted-foreground mb-3">
                          Collect cash on delivery amount
                        </p>
                        <div className="flex items-center gap-2">
                          <span className="text-2xl font-bold text-chart-4">
                            {formatCurrency(
                              getShipmentForDelivery(selectedDelivery || '')?.codAmount || 0
                            )}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <Separator />

                  <Button className="w-full gap-2" size="lg">
                    <CheckCircle className="h-5 w-5" />
                    Complete Delivery
                  </Button>
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          {/* Earnings Tab */}
          <TabsContent value="earnings" className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
              <Card>
                <CardHeader>
                  <CardTitle>Today's Summary</CardTitle>
                  <CardDescription>{formatDate(new Date(), 'long')}</CardDescription>
                </CardHeader>
                <CardContent className="space-y-6">
                  <div>
                    <div className="flex items-center justify-between mb-2">
                      <span className="text-sm text-muted-foreground">Total Earnings</span>
                      <span className="text-2xl font-bold text-chart-4">
                        {formatCurrency(todayEarnings)}
                      </span>
                    </div>
                    <Progress value={75} className="h-2" />
                  </div>

                  <Separator />

                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-muted-foreground">Deliveries Completed</span>
                      <span className="font-semibold">{completedToday.length}</span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-muted-foreground">COD Collected</span>
                      <span className="font-semibold">{formatCurrency(codCollectedToday)}</span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-muted-foreground">Average per Delivery</span>
                      <span className="font-semibold">
                        {formatCurrency(
                          completedToday.length > 0 ? todayEarnings / completedToday.length : 0
                        )}
                      </span>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle>Performance Metrics</CardTitle>
                  <CardDescription>Your overall statistics</CardDescription>
                </CardHeader>
                <CardContent className="space-y-6">
                  <div className="space-y-4">
                    <div>
                      <div className="flex items-center justify-between mb-2">
                        <span className="text-sm text-muted-foreground">Success Rate</span>
                        <span className="font-semibold">
                          {((currentDriver?.performance?.successRate) ?? 0).toFixed(1)}%
                        </span>
                      </div>
                      <Progress
                        value={currentDriver?.performance?.successRate || 0}
                        className="h-2"
                      />
                    </div>

                    <div>
                      <div className="flex items-center justify-between mb-2">
                        <span className="text-sm text-muted-foreground">On-Time Rate</span>
                        <span className="font-semibold">
                          {((currentDriver?.performance?.onTimeRate) ?? 0).toFixed(1)}%
                        </span>
                      </div>
                      <Progress
                        value={currentDriver?.performance?.onTimeRate || 0}
                        className="h-2"
                      />
                    </div>

                    <div>
                      <div className="flex items-center justify-between mb-2">
                        <span className="text-sm text-muted-foreground">Customer Rating</span>
                        <span className="font-semibold">
                          {((currentDriver?.performance?.averageRating) ?? 0).toFixed(1)}/5.0
                        </span>
                      </div>
                      <Progress
                        value={(currentDriver?.performance?.averageRating || 0) * 20}
                        className="h-2"
                      />
                    </div>
                  </div>

                  <Separator />

                  <div className="flex items-center justify-between">
                    <span className="text-sm text-muted-foreground">Total Deliveries</span>
                    <span className="text-2xl font-bold">
                      {currentDriver?.performance?.totalDeliveries || 0}
                    </span>
                  </div>
                </CardContent>
              </Card>
            </div>

            <Card>
              <CardHeader>
                <CardTitle>Recent Deliveries</CardTitle>
                <CardDescription>Your completed deliveries today</CardDescription>
              </CardHeader>
              <CardContent>
                <ScrollArea className="h-[400px] pr-4">
                  <div className="space-y-3">
                    {completedToday.map((delivery) => {
                      const shipment = getShipmentForDelivery(delivery.id);
                      if (!shipment) return null;

                      return (
                        <div
                          key={delivery.id}
                          className="flex items-center justify-between p-4 rounded-lg border border-border hover:border-chart-3 transition-colors"
                        >
                          <div className="flex items-center gap-3">
                            <div className="h-10 w-10 rounded-full bg-chart-3/10 flex items-center justify-center">
                              <CheckCircle className="h-5 w-5 text-chart-3" />
                            </div>
                            <div>
                              <p className="font-medium">{shipment.recipient.name}</p>
                              <p className="text-sm text-muted-foreground">
                                {delivery.deliveredAt && formatDate(delivery.deliveredAt, 'time')}
                              </p>
                            </div>
                          </div>
                          <div className="text-right">
                            <p className="font-semibold">{formatCurrency(5000)}</p>
                            {delivery.codCollected && (
                              <p className="text-sm text-chart-4">
                                COD: {formatCurrency(delivery.codCollected)}
                              </p>
                            )}
                          </div>
                        </div>
                      );
                    })}

                    {completedToday.length === 0 && (
                      <div className="text-center py-12">
                        <DollarSign className="h-12 w-12 text-muted-foreground mx-auto mb-4" />
                        <p className="text-muted-foreground">No completed deliveries today</p>
                      </div>
                    )}
                  </div>
                </ScrollArea>
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
