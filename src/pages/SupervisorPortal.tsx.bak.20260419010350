import { useState, useMemo } from 'react';
import { useLocation } from 'react-router-dom';
import { motion } from 'framer-motion';
import {
  Package,
  TrendingUp,
  Users,
  AlertTriangle,
  Clock,
  MapPin,
  CheckCircle,
  XCircle,
  Filter,
  Download,
  RefreshCw,
  Search,
  MoreVertical,
  Truck,
  Calendar,
  Activity,
} from 'lucide-react';
import { IMAGES } from '@/assets/images';
import {
  Delivery,
  Employee,
  Task,
  Warehouse,
  formatStatus,
  formatDate,
  formatCurrency,
  calculateDeliveryMetrics,
} from '@/lib/index';
import {
  mockDeliveries,
  mockEmployees,
  mockTasks,
  mockWarehouses,
  mockShipments,
} from '@/data/index';
import { MetricCard, StatsGrid, StatusBadge, CompactMetric } from '@/components/Stats';
import { DeliveryTrendChart, StatusDistributionChart } from '@/components/Charts';
import { DataTable, Column } from '@/components/DataTable';
import { MapView } from '@/components/MapView';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Badge } from '@/components/ui/badge';
import { Separator } from '@/components/ui/separator';
import { ScrollArea } from '@/components/ui/scroll-area';
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu';

export default function SupervisorPortal() {
  const [searchQuery, setSearchQuery] = useState('');
  const location = useLocation();
  const getInitialView = () => {
    if (location.pathname.includes('/overview')) return 'overview';
    if (location.pathname.includes('/queue')) return 'queue';
    if (location.pathname.includes('/exceptions')) return 'exceptions';
    if (location.pathname.includes('/fleet')) return 'fleet';
    return 'overview';
  };
  const [statusFilter, setStatusFilter] = useState<string>('all');
  const [selectedView, setSelectedView] = useState<'overview' | 'queue' | 'fleet' | 'exceptions'>(getInitialView());

  const metrics = useMemo(() => calculateDeliveryMetrics(mockDeliveries), []);

  const drivers = useMemo(
    () => mockEmployees.filter((emp) => emp.role === 'driver' && emp.status === 'active'),
    []
  );

  const overnightQueue = useMemo(
    () =>
      mockDeliveries.filter(
        (d) => d.status === 'pending' || d.status === 'assigned'
      ),
    []
  );

  const exceptions = useMemo(
    () =>
      mockDeliveries.filter(
        (d) => d.status === 'failed' || d.ndrCase
      ),
    []
  );

  const urgentTasks = useMemo(
    () => mockTasks.filter((t) => t.priority === 'urgent' || t.priority === 'high'),
    []
  );

  const deliveryColumns: Column<Delivery>[] = [
    {
      id: 'id',
      header: 'Delivery ID',
      cell: (delivery) => (
        <span className="font-mono text-sm font-medium">{delivery.id}</span>
      ),
    },
    {
      id: 'shipmentId',
      header: 'Shipment',
      cell: (delivery) => {
        const shipment = mockShipments.find((s) => s.id === delivery.shipmentId);
        return (
          <div className="space-y-1">
            <div className="font-mono text-sm">{shipment?.awb || 'N/A'}</div>
            <div className="text-xs text-muted-foreground">{shipment?.recipient.name}</div>
          </div>
        );
      },
    },
    {
      id: 'status',
      header: 'Status',
      cell: (delivery) => <StatusBadge status={delivery.status} />,
    },
    {
      id: 'driverId',
      header: 'Driver',
      cell: (delivery) => {
        const driver = mockEmployees.find((e) => e.id === delivery.driverId);
        return driver ? (
          <div className="flex items-center gap-2">
            <div className="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center">
              <Users className="h-4 w-4 text-primary" />
            </div>
            <span className="text-sm">{driver.name}</span>
          </div>
        ) : (
          <span className="text-sm text-muted-foreground">Unassigned</span>
        );
      },
    },
    {
      id: 'assignedAt',
      header: 'Assigned',
      cell: (delivery) =>
        delivery.assignedAt ? (
          <span className="text-sm">{formatDate(delivery.assignedAt, 'datetime')}</span>
        ) : (
          <span className="text-sm text-muted-foreground">-</span>
        ),
    },
  ];

  const exceptionColumns: Column<Delivery>[] = [
    {
      id: 'id',
      header: 'Delivery ID',
      cell: (delivery) => (
        <span className="font-mono text-sm font-medium">{delivery.id}</span>
      ),
    },
    {
      id: 'failureReason',
      header: 'Reason',
      cell: (delivery) => (
        <div className="space-y-1">
          <div className="text-sm font-medium">{delivery.failureReason || 'Unknown'}</div>
          {delivery.ndrCase && (
            <div className="text-xs text-muted-foreground">
              Attempts: {delivery.ndrCase.attempts}
            </div>
          )}
        </div>
      ),
    },
    {
      id: 'failedAt',
      header: 'Failed At',
      cell: (delivery) =>
        delivery.failedAt ? (
          <span className="text-sm">{formatDate(delivery.failedAt, 'datetime')}</span>
        ) : (
          <span className="text-sm text-muted-foreground">-</span>
        ),
    },
    {
      id: 'ndrCase',
      header: 'Next Attempt',
      cell: (delivery) =>
        delivery.ndrCase?.nextAttemptDate ? (
          <span className="text-sm">{formatDate(delivery.ndrCase.nextAttemptDate, 'datetime')}</span>
        ) : (
          <span className="text-sm text-muted-foreground">-</span>
        ),
    },
  ];

  const chartData = useMemo(() => {
    const last7Days = Array.from({ length: 7 }, (_, i) => {
      const date = new Date();
      date.setDate(date.getDate() - (6 - i));
      return {
        date: date.toISOString().split('T')[0],
        delivered: Math.floor(Math.random() * 50) + 30,
        failed: Math.floor(Math.random() * 10) + 2,
        pending: Math.floor(Math.random() * 20) + 10,
      };
    });
    return last7Days;
  }, []);

  const statusData = useMemo(() => [
    { name: 'Delivered', value: metrics.delivered, color: 'hsl(var(--chart-3))' },
    { name: 'Pending', value: metrics.pending, color: 'hsl(var(--chart-1))' },
    { name: 'Failed', value: metrics.failed, color: 'hsl(var(--destructive))' },
  ], [metrics]);

  return (
    <div className="min-h-screen bg-background">
      <div
        className="absolute inset-0 z-0 opacity-30"
        style={{
          backgroundImage: `url(${IMAGES.SCREENSHOT_3252_2})`,
          backgroundSize: 'cover',
          backgroundPosition: 'center',
        }}
      />
      <div className="absolute inset-0 bg-gradient-to-b from-background/50 via-transparent to-background/70" />

      <div className="relative z-10">
        <div className="border-b border-border/40 bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60">
          <div className="container mx-auto px-4 py-6">
            <div className="flex items-center justify-between">
              <div>
                <h1 className="text-3xl font-bold tracking-tight">Supervisor Portal</h1>
                <p className="text-muted-foreground mt-1">
                  Operational dashboard and team management
                </p>
              </div>
              <div className="flex items-center gap-3">
                <Button variant="outline" size="sm">
                  <RefreshCw className="h-4 w-4 mr-2" />
                  Refresh
                </Button>
                <Button variant="outline" size="sm">
                  <Download className="h-4 w-4 mr-2" />
                  Export
                </Button>
                <Button size="sm">
                  <Filter className="h-4 w-4 mr-2" />
                  Filters
                </Button>
              </div>
            </div>
          </div>
        </div>

        <div className="container mx-auto px-4 py-8 space-y-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.4 }}
          >
            <StatsGrid
              metrics={[
                {
                  title: 'Total Deliveries',
                  value: metrics.total,
                  icon: <Package className="h-5 w-5" />,
                  trend: 12.5,
                },
                {
                  title: 'Success Rate',
                  value: `${metrics.successRate}%`,
                  icon: <CheckCircle className="h-5 w-5" />,
                  trend: 2.3,
                },
                {
                  title: 'On-Time Rate',
                  value: `${metrics.onTimeRate}%`,
                  icon: <Clock className="h-5 w-5" />,
                  trend: 1.8,
                },
                {
                  title: 'Active Drivers',
                  value: drivers.length,
                  icon: <Users className="h-5 w-5" />,
                  trend: 0,
                },
                {
                  title: 'Pending Queue',
                  value: overnightQueue.length,
                  icon: <AlertTriangle className="h-5 w-5" />,
                  trend: -8.4,
                },
                {
                  title: 'Exceptions',
                  value: exceptions.length,
                  icon: <XCircle className="h-5 w-5" />,
                  trend: -12.1,
                },
              ]}
            />
          </motion.div>

          <Tabs value={selectedView} onValueChange={(v) => setSelectedView(v as any)} className="space-y-6">
            <TabsList className="grid w-full grid-cols-4">
              <TabsTrigger value="overview">Overview</TabsTrigger>
              <TabsTrigger value="queue">Queue Management</TabsTrigger>
              <TabsTrigger value="fleet">Fleet Mobility</TabsTrigger>
              <TabsTrigger value="exceptions">Exceptions</TabsTrigger>
            </TabsList>

            <TabsContent value="overview" className="space-y-6">
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <Card>
                  <CardHeader>
                    <CardTitle>Delivery Trends</CardTitle>
                    <CardDescription>Last 7 days performance</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <DeliveryTrendChart data={chartData} height={300} />
                  </CardContent>
                </Card>

                <Card>
                  <CardHeader>
                    <CardTitle>Status Distribution</CardTitle>
                    <CardDescription>Current delivery status breakdown</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <StatusDistributionChart data={statusData} height={300} />
                  </CardContent>
                </Card>
              </div>

              <Card>
                <CardHeader>
                  <CardTitle>Leadership Performance</CardTitle>
                  <CardDescription>Team member performance metrics</CardDescription>
                </CardHeader>
                <CardContent>
                  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {drivers.slice(0, 6).map((driver) => (
                      <motion.div
                        key={driver.id}
                        whileHover={{ scale: 1.02 }}
                        className="p-4 rounded-lg border border-border bg-card"
                      >
                        <div className="flex items-start justify-between mb-3">
                          <div className="flex items-center gap-3">
                            <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center">
                              <Users className="h-5 w-5 text-primary" />
                            </div>
                            <div>
                              <div className="font-semibold">{driver.name}</div>
                              <div className="text-xs text-muted-foreground">
                                {driver.employeeNumber}
                              </div>
                            </div>
                          </div>
                          <Badge variant="outline" className="text-xs">
                            {driver.vehicleAssignment?.vehicleType}
                          </Badge>
                        </div>
                        <Separator className="my-3" />
                        <div className="grid grid-cols-2 gap-3">
                          <CompactMetric
                            label="Deliveries"
                            value={driver.performance?.totalDeliveries || 0}
                            icon={<Package className="h-3 w-3" />}
                          />
                          <CompactMetric
                            label="Success Rate"
                            value={`${driver.performance?.successRate || 0}%`}
                            icon={<TrendingUp className="h-3 w-3" />}
                          />
                          <CompactMetric
                            label="On-Time"
                            value={`${driver.performance?.onTimeRate || 0}%`}
                            icon={<Clock className="h-3 w-3" />}
                          />
                          <CompactMetric
                            label="Rating"
                            value={driver.performance?.averageRating || 0}
                            icon={<Activity className="h-3 w-3" />}
                          />
                        </div>
                      </motion.div>
                    ))}
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle>Urgent Tasks</CardTitle>
                  <CardDescription>High priority tasks requiring attention</CardDescription>
                </CardHeader>
                <CardContent>
                  <ScrollArea className="h-[300px]">
                    <div className="space-y-3">
                      {urgentTasks.map((task) => (
                        <div
                          key={task.id}
                          className="p-4 rounded-lg border border-border bg-card hover:bg-accent/5 transition-colors"
                        >
                          <div className="flex items-start justify-between">
                            <div className="flex-1">
                              <div className="flex items-center gap-2 mb-2">
                                <Badge
                                  variant={task.priority === 'urgent' ? 'destructive' : 'default'}
                                  className="text-xs"
                                >
                                  {task.priority}
                                </Badge>
                                <Badge variant="outline" className="text-xs">
                                  {task.type}
                                </Badge>
                              </div>
                              <div className="font-semibold mb-1">{task.title}</div>
                              <div className="text-sm text-muted-foreground mb-2">
                                {task.description}
                              </div>
                              <div className="flex items-center gap-4 text-xs text-muted-foreground">
                                <div className="flex items-center gap-1">
                                  <Calendar className="h-3 w-3" />
                                  {task.dueDate ? formatDate(task.dueDate, 'datetime') : 'No due date'}
                                </div>
                                {task.assignedTo && (
                                  <div className="flex items-center gap-1">
                                    <Users className="h-3 w-3" />
                                    {mockEmployees.find((e) => e.id === task.assignedTo)?.name || 'Unknown'}
                                  </div>
                                )}
                              </div>
                            </div>
                            <DropdownMenu>
                              <DropdownMenuTrigger asChild>
                                <Button variant="ghost" size="sm">
                                  <MoreVertical className="h-4 w-4" />
                                </Button>
                              </DropdownMenuTrigger>
                              <DropdownMenuContent align="end">
                                <DropdownMenuLabel>Actions</DropdownMenuLabel>
                                <DropdownMenuSeparator />
                                <DropdownMenuItem>View Details</DropdownMenuItem>
                                <DropdownMenuItem>Reassign</DropdownMenuItem>
                                <DropdownMenuItem>Mark Complete</DropdownMenuItem>
                              </DropdownMenuContent>
                            </DropdownMenu>
                          </div>
                        </div>
                      ))}
                    </div>
                  </ScrollArea>
                </CardContent>
              </Card>
            </TabsContent>

            <TabsContent value="queue" className="space-y-6">
              <Card>
                <CardHeader>
                  <div className="flex items-center justify-between">
                    <div>
                      <CardTitle>Overnight Delivery Queue</CardTitle>
                      <CardDescription>
                        {overnightQueue.length} deliveries pending assignment
                      </CardDescription>
                    </div>
                    <div className="flex items-center gap-2">
                      <Input
                        placeholder="Search deliveries..."
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        className="w-64"
                      />
                      <Select value={statusFilter} onValueChange={setStatusFilter}>
                        <SelectTrigger className="w-40">
                          <SelectValue placeholder="Status" />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="all">All Status</SelectItem>
                          <SelectItem value="pending">Pending</SelectItem>
                          <SelectItem value="assigned">Assigned</SelectItem>
                        </SelectContent>
                      </Select>
                    </div>
                  </div>
                </CardHeader>
                <CardContent>
                  <DataTable
                    columns={deliveryColumns}
                    data={overnightQueue}
                    searchable
                    filterable
                  />
                </CardContent>
              </Card>

              <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <Card>
                  <CardHeader>
                    <CardTitle className="text-base">Bulk Actions</CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-2">
                    <Button className="w-full justify-start" variant="outline">
                      <Users className="h-4 w-4 mr-2" />
                      Auto-Assign to Drivers
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <MapPin className="h-4 w-4 mr-2" />
                      Optimize Routes
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <Calendar className="h-4 w-4 mr-2" />
                      Schedule for Tomorrow
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <Download className="h-4 w-4 mr-2" />
                      Export Queue
                    </Button>
                  </CardContent>
                </Card>

                <Card className="lg:col-span-2">
                  <CardHeader>
                    <CardTitle className="text-base">Queue Statistics</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="grid grid-cols-2 gap-4">
                      <CompactMetric
                        label="Total in Queue"
                        value={overnightQueue.length}
                        icon={<Package className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Unassigned"
                        value={overnightQueue.filter((d) => !d.driverId).length}
                        icon={<AlertTriangle className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Assigned"
                        value={overnightQueue.filter((d) => d.driverId).length}
                        icon={<CheckCircle className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Avg Wait Time"
                        value="2.5h"
                        icon={<Clock className="h-4 w-4" />}
                      />
                    </div>
                  </CardContent>
                </Card>
              </div>
            </TabsContent>

            <TabsContent value="fleet" className="space-y-6">
              <Card>
                <CardHeader>
                  <CardTitle>Fleet Mobility Tracking</CardTitle>
                  <CardDescription>Real-time driver locations and routes</CardDescription>
                </CardHeader>
                <CardContent>
                  <div className="h-[500px] rounded-lg overflow-hidden border border-border">
                    <MapView
                      deliveries={mockDeliveries}
                      drivers={drivers}
                      warehouses={mockWarehouses}
                    />
                  </div>
                </CardContent>
              </Card>

              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <Card>
                  <CardHeader>
                    <CardTitle>Active Drivers</CardTitle>
                    <CardDescription>{drivers.length} drivers currently active</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <ScrollArea className="h-[400px]">
                      <div className="space-y-3">
                        {drivers.map((driver) => (
                          <div
                            key={driver.id}
                            className="p-4 rounded-lg border border-border bg-card"
                          >
                            <div className="flex items-center justify-between mb-3">
                              <div className="flex items-center gap-3">
                                <div className="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center">
                                  <Truck className="h-5 w-5 text-primary" />
                                </div>
                                <div>
                                  <div className="font-semibold">{driver.name}</div>
                                  <div className="text-xs text-muted-foreground">
                                    {driver.vehicleAssignment?.licensePlate}
                                  </div>
                                </div>
                              </div>
                              <Badge variant="outline" className="text-xs">
                                Active
                              </Badge>
                            </div>
                            <div className="grid grid-cols-3 gap-2 text-xs">
                              <div>
                                <div className="text-muted-foreground">Today</div>
                                <div className="font-semibold">12 deliveries</div>
                              </div>
                              <div>
                                <div className="text-muted-foreground">Success</div>
                                <div className="font-semibold">95%</div>
                              </div>
                              <div>
                                <div className="text-muted-foreground">Location</div>
                                <div className="font-semibold flex items-center gap-1">
                                  <MapPin className="h-3 w-3" />
                                  Live
                                </div>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </ScrollArea>
                  </CardContent>
                </Card>

                <Card>
                  <CardHeader>
                    <CardTitle>Fleet Statistics</CardTitle>
                    <CardDescription>Current fleet performance</CardDescription>
                  </CardHeader>
                  <CardContent className="space-y-6">
                    <div className="grid grid-cols-2 gap-4">
                      <CompactMetric
                        label="Total Vehicles"
                        value={drivers.length}
                        icon={<Truck className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Active Now"
                        value={drivers.length}
                        icon={<Activity className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Avg Speed"
                        value="45 km/h"
                        icon={<TrendingUp className="h-4 w-4" />}
                      />
                      <CompactMetric
                        label="Total Distance"
                        value="1,234 km"
                        icon={<MapPin className="h-4 w-4" />}
                      />
                    </div>

                    <Separator />

                    <div className="space-y-3">
                      <div className="text-sm font-semibold">Vehicle Types</div>
                      <div className="space-y-2">
                        <div className="flex items-center justify-between text-sm">
                          <span className="text-muted-foreground">Bikes</span>
                          <span className="font-semibold">8</span>
                        </div>
                        <div className="flex items-center justify-between text-sm">
                          <span className="text-muted-foreground">Vans</span>
                          <span className="font-semibold">12</span>
                        </div>
                        <div className="flex items-center justify-between text-sm">
                          <span className="text-muted-foreground">Trucks</span>
                          <span className="font-semibold">4</span>
                        </div>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </div>
            </TabsContent>

            <TabsContent value="exceptions" className="space-y-6">
              <Card>
                <CardHeader>
                  <div className="flex items-center justify-between">
                    <div>
                      <CardTitle>Exception Handling</CardTitle>
                      <CardDescription>
                        {exceptions.length} failed deliveries requiring attention
                      </CardDescription>
                    </div>
                    <Button size="sm">
                      <RefreshCw className="h-4 w-4 mr-2" />
                      Refresh
                    </Button>
                  </div>
                </CardHeader>
                <CardContent>
                  <DataTable
                    columns={exceptionColumns}
                    data={exceptions}
                    searchable
                    filterable
                  />
                </CardContent>
              </Card>

              <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <Card>
                  <CardHeader>
                    <CardTitle className="text-base">Quick Actions</CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-2">
                    <Button className="w-full justify-start" variant="outline">
                      <RefreshCw className="h-4 w-4 mr-2" />
                      Retry All Failed
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <Users className="h-4 w-4 mr-2" />
                      Reassign to Drivers
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <Calendar className="h-4 w-4 mr-2" />
                      Schedule Reattempts
                    </Button>
                    <Button className="w-full justify-start" variant="outline">
                      <XCircle className="h-4 w-4 mr-2" />
                      Mark as Cancelled
                    </Button>
                  </CardContent>
                </Card>

                <Card className="lg:col-span-2">
                  <CardHeader>
                    <CardTitle className="text-base">Exception Analysis</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="space-y-4">
                      <div className="grid grid-cols-2 gap-4">
                        <CompactMetric
                          label="Total Exceptions"
                          value={exceptions.length}
                          icon={<XCircle className="h-4 w-4" />}
                        />
                        <CompactMetric
                          label="NDR Cases"
                          value={exceptions.filter((e) => e.ndrCase).length}
                          icon={<AlertTriangle className="h-4 w-4" />}
                        />
                      </div>

                      <Separator />

                      <div className="space-y-3">
